{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/puuid", "dest": "/api/puuid.js" },
    { "src": "/api/matches", "dest": "/api/matches.js" },
    { "src": "/api/match", "dest": "/api/match.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
